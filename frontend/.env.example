# Frontend Environment Configuration Template
# Copy this to .env.local and fill in actual values

# API Configuration
VITE_API_BASE_URL=http://localhost:8000/api/v1

# Environment
VITE_ENV=development

# Feature Flags (Optional)
# VITE_ENABLE_ANALYTICS=false
# VITE_ENABLE_ERROR_TRACKING=false

# Notes:
# - VITE_* prefix variables are available in frontend code via import.meta.env
# - .env.local is not committed to git
# - For production, use .env.production with different values
